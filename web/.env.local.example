# Supabase — copy to .env.local and fill in from your Supabase project settings (API).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser. Bypasses RLS — used by the trusted server API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret the n8n automation uses to authenticate to this app's API.
AUTOMATION_API_KEY=generate-a-long-random-string
